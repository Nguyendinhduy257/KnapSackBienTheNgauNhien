@model List<KnapSackBienTheNgauNhien.Models.VatPham>
@{
    ViewData["Title"] = "Bước 2: Xếp Balo";
}

<link rel="stylesheet" href="~/css/knapsack.css" />

<div class="knapsack-container">
    <h2 style="text-align:center; color: #FFD700; text-transform: uppercase; letter-spacing: 2px;">Phân loại vật phẩm</h2>

    <div class="controls">
        <a href="/Knapsack/Index" class="btn btn-secondary">⬅ Quay lại xoay vật phẩm mới</a>
        <button class="btn btn-success" id="btn-ai-solve">Tự động xếp bằng AI</button>
    </div>

    <h3 class="zone-header">Kho vật phẩm chờ phân loại</h3>
    <div class="item-grid" id="source-zone">
        @foreach (var item in Model)
        {
            <div class="item-card" draggable="true" id="item-@item.Id"
                 data-weight="@item.TrongLuong" data-value="@item.GiaTri">
                <h4 style="color: #FFD700; font-size: 16px; margin-bottom: 10px;">Vật phẩm @item.Ten</h4>
                <p><strong>Khối lượng:</strong> @item.TrongLuong kg</p>
                <p><strong>Giá trị:</strong> $@item.GiaTri</p>
                <p><strong>Tỷ lệ:</strong> @item.TyLe.ToString("0.00")</p>
            </div>
        }
    </div>

    <div class="status-dashboard">
        <div class="status-info">
            <div style="display: flex; justify-content: space-between; font-size: 16px;">
                <span>Trọng lượng: <strong id="current-weight">0</strong> / <span id="max-capacity">@ViewBag.SucChua</span> kg</span>
                <span>Giá trị thu thập: <strong id="current-value" style="color: #FFD700; font-size: 20px;">$0</strong></span>
            </div>
            <div class="progress">
                <div class="progress-bar" id="weight-progress" style="width: 0%;"></div>
            </div>
        </div>

        <div class="donut-chart-container" title="Tỷ lệ lấp đầy Balo">
            <div class="donut-chart" id="capacity-donut" style="--percent: 0%;">
                <div class="donut-inner">
                    <span id="donut-text">0%</span>
                </div>
            </div>
        </div>
    </div>

    <h3 class="zone-header">Balo chứa đồ (Kéo thả vào đây)</h3>
    <div class="backpack-zone item-grid" id="backpack-zone">
    </div>
</div>

<script src="~/js/knapsack-game.js"></script>